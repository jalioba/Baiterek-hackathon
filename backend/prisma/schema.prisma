generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  role        String   @default("USER")
  firstName   String
  lastName    String
  phone       String?
  iin         String?
  bin         String?
  companyName String?
  companyType String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
